# ============================================================================
# Frontend (exposed to the browser — must be prefixed VITE_)
# Get these from: Supabase Dashboard → Project Settings → API
# ============================================================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ============================================================================
# Serverless functions only (api/admin.js, api/import.js, api/health.js)
# NEVER prefix these with VITE_ — that would expose them to the browser.
# Set these in Vercel Project Settings → Environment Variables, and in a
# local .env file for `vercel dev` / local testing of the functions.
# Get the service role key from: Supabase Dashboard → Project Settings → API
# (the "service_role" secret key — keep this out of git, out of the client,
# and never share it).
# ============================================================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
